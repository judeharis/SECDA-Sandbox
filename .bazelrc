# Enable Bzlmod for every Bazel command
common --enable_bzlmod
# common --lockfile_mode=off
# common --registry=file:///mnt/Crucial/WorkspaceB/bazel-central-registry/
common --registry=https://raw.githubusercontent.com/judeharis/bazel-central-registry/main/
# common --registry=file:///home/jude/Workspace/SECDA/bazel-central-registry/



# Prevent Bazel from detecting the system's C++ toolchain.
# build --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
build --incompatible_strict_action_env=true
# Enable the CC toolchain resolution based on platforms.
build --incompatible_enable_cc_toolchain_resolution